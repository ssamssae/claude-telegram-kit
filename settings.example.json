{
  "_comment": "Legacy manual install only. Plugin installs load hooks/hooks.json automatically. If you use install.sh, merge these hook blocks into ~/.claude/settings.json and add to existing arrays rather than replacing the whole file.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/session-device-id.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode|EnterPlanMode",
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/telegram-ui-guard.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "~/.claude/hooks/telegram-reply-check.sh" }
        ]
      }
    ]
  }
}
