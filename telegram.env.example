# Optional env for the Telegram kit. Source this from your shell profile or a
# hook wrapper. NONE of these are required for the core reply-enforcement hook —
# the reply-check and ui-guard hooks read everything they need from the
# transcript. These only customize behavior.
#
# Copy to telegram.env and fill in. NEVER commit the real file — it is gitignored.

# If your Telegram plugin exposes the reply tool under a different name, set it
# here so telegram-reply-check.sh matches the right tool.
# TELEGRAM_REPLY_TOOL=mcp__plugin_telegram_telegram__reply

# Single-machine device prefix (alternative to devices.conf):
# TELEGRAM_DEVICE_EMOJI=💻
# TELEGRAM_DEVICE_LABEL=laptop
#
# For plugin installs, the default local devices.conf path is:
#   ~/.claude/claude-telegram-kit/devices.conf

# Your bot token and chat identifier live in the Telegram MCP plugin's own
# config, NOT here. This kit never needs your bot token. Do not put it in this
# file.
